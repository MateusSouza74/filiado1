# =============================================
# Affiliate Bot - Configuração
# =============================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# NUNCA commite o arquivo .env no git!
# =============================================

# --- Credenciais Telegram (Telethon) ---
# Obtenha em: https://my.telegram.org/auth -> API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=sua_hash_aqui_32_caracteres

# Nome do arquivo de sessão Telethon (pode deixar o padrão)
SESSION_NAME=sessao_affiliate_bot

# --- Bot Telegram ---
# Token do seu bot (obtido via @BotFather)
BOT_TOKEN=1234567890:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Canal onde as ofertas serão postadas
# Use o ID numérico (ex: -1001234567890) ou @username
CANAL_DESTINO=-1001234567890

# --- Canais para monitorar ---
# Separe múltiplos canais por vírgula (sem espaço)
CANAIS_ORIGEM=@LaPromotion,@SamuelF3lipePromo

# --- Códigos de Afiliado ---

# Amazon Associates: sua tag (ex: MeuCanal-20)
AMAZON_TAG=SeuNome-20

# Lomadee: seu Source ID (painel Lomadee -> Ferramentas -> Source ID)
LOMADEE_SOURCE_ID=seu-source-id-aqui

# Shopee Affiliates: seu ID de afiliado
SHOPEE_AFFILIATE_ID=

# --- Configurações de Comportamento ---

# Modo debug: true = logs detalhados | false = apenas info
DEBUG=false

# Tempo em horas para considerar um link como duplicata (padrão: 24h)
DUPLICATA_TTL_HORAS=24

# Timeout para download de mídia do Telegram (segundos)
MEDIA_DOWNLOAD_TIMEOUT=10

# Pasta do perfil Chrome para login persistente do Mercado Livre
# (não precisa alterar, deixe o padrão)
CHROME_PROFILE_DIR=ml_chrome_profile
